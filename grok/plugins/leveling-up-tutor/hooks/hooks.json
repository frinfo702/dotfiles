{
  "description": "Leveling Up Tutor: block code writes, inject progress at session start, assess learning on stop",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/session-start.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "search_replace|write|Write|Edit|MultiEdit|StrReplace|Create|Delete|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/block-writes.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|run_terminal_command|Shell",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/block-writes.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT}/hooks/session-stop.sh\"",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
