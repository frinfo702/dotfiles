{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "websearch": "allow"
  },
  "lsp": true,
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max"
    },
    "plan": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max"
    },
    "general": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max"
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max"
    },
    "scout": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max"
    },
    "compaction": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "hidden": true
    },
    "summary": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "hidden": true
    },
    "title": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "hidden": true
    }
  },
  "provider": {
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "{env:NVIDIA_API_KEY}"
      },
      "models": {
        "deepseek-ai/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "google-scholar": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@smithery/cli@latest",
        "run",
        "@JackKuo666/google-scholar-mcp-server"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}
