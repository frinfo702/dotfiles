/factory/

# ============================================
# History / Log / Cache - conflict-prone files
# ============================================

# Shell history
*.history
.zsh_history
.bash_history

# Log files
*.log

# JSONL history files
*.jsonl

# Cache directories
**/cache/
**/__pycache__/

# Session data (machine-specific paths, changes constantly)
**/sessions/

# Database files (binary, machine-specific)
*.db
*.db-wal
*.db-shm

# Lock files
**/locks/

# --------------------------------------------
# .pi/agent - runtime caches & history
# --------------------------------------------
.pi/agent/auth.json
.pi/agent/run-history.jsonl
.pi/agent/mcp-cache.json
.pi/agent/mcp-npx-cache.json
.pi/agent/sessions/

# .pi/pi-acp - session mapping
.pi/pi-acp/

# --------------------------------------------
# cline/data - runtime data (caches, DBs, logs, sessions)
# --------------------------------------------
cline/data/cache/
cline/data/db/
cline/data/locks/
cline/data/logs/
cline/data/sessions/
cline/data/settings/providers.json
cline/data/settings/cli-notices.json

# cline installed plugins from git (nested repos; dirty constantly)
cline/plugins/_installed/git/

# --------------------------------------------
# .cursor - state files
# --------------------------------------------
.cursor/hooks/state/

# cursor/ (dotfiles copy of ~/.cursor) — runtime / machine-local
# Final ignores live after CURSOR MANAGED BLOCK in cursor/.gitignore
cursor/projects/
cursor/plugins/cache/
cursor/skills-cursor/.sync-manifest.json
cursor/skills-cursor/.cursor-managed-skills-manifest.json

# --------------------------------------------
# opencode - generated artifacts
# --------------------------------------------
opencode/skills/skill-creator/scripts/__pycache__/

# --------------------------------------------
# nvim - lock/state (changes frequently)
# --------------------------------------------
nvim/lazy-lock.json
nvim/lazyvim.json

# --------------------------------------------
# Finder metadata
# --------------------------------------------
.DS_Store
**/.DS_Store

# --------------------------------------------
# grok - allowlist only (shared config)
# Track: config.toml, skills/, plugins/
# Runtime CLI state (auth, sessions, installed-plugins,
# marketplace-cache, bin, logs, …) stays ignored by grok/*
# Never force-add auth.json or other CLI state.
# --------------------------------------------
grok/*
!grok/config.toml
!grok/skills/
!grok/skills/**
!grok/plugins/
!grok/plugins/**

# --------------------------------------------
# codex - allowlist only (shared configuration)
# Track: config.toml, AGENTS.md, rules/
# Runtime state (auth, history, sessions, caches, databases,
# plugins, generated images, machine identifiers, …) stays ignored.
# --------------------------------------------
codex/*
!codex/config.toml
!codex/AGENTS.md
!codex/rules/
!codex/rules/default.rules

# --------------------------------------------
# Zed
# --------------------------------------------
zed/*.bak.*
zed/settings_backup.json
